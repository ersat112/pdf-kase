+export const documentActionCopy = {
+  library: {
+    short: 'Belge merkezi',
+  },
+  edit: {
+    short: 'Düzenle',
+    caption: 'Kaşe, imza ve sayfalar',
+  },
+  ocr: {
+    short: 'OCR',
+    retry: 'OCR tekrar dene',
+    caption: 'Sayfalardaki metni algıla',
+  },
+  pdf: {
+    create: 'PDF üret',
+    refresh: 'PDF yenile',
+    share: 'PDF paylaş',
+    captionCreate: 'Güncel sayfalardan PDF oluştur',
+    captionRefresh: 'Mevcut PDF çıktısını güncelle',
+  },
+  word: {
+    short: 'Word',
+    create: 'Word üret',
+    refresh: 'Word yenile',
+    share: 'Word paylaş',
+    captionCreate: 'OCR metnini Word olarak hazırla',
+    captionRefresh: 'Mevcut Word çıktısını güncelle',
+  },
+  excel: {
+    create: 'Excel üret',
+    caption: 'OCR metnini Excel olarak hazırla',
+  },
+  translate: {
+    short: 'Çevir',
+    caption: 'OCR metnini Türkçeye çevir',
+  },
+  share: {
+    short: 'Paylaş',
+    captionReady: 'PDF hazır',
+    captionNeedsPdf: 'Önce PDF',
+  },
+  print: {
+    short: 'Yazdır',
+    captionReady: 'Sistem paneli',
+    captionNeedsPdf: 'Önce PDF',
+  },
+  editor: {
+    assetLibrary: 'Kaşe & İmzalar',
+    smartErase: 'Akıllı sil',
+    saveAndBack: 'Kaydet ve dön',
+    previousPage: 'Önceki sayfa',
+    nextPage: 'Sonraki sayfa',
+    newSignature: 'Yeni imza',
+  },
+} as const;
+
+export function getPdfActionLabel(hasPdf: boolean) {
+  return hasPdf ? documentActionCopy.pdf.refresh : documentActionCopy.pdf.create;
+}
+
+export function getWordActionLabel(hasWord: boolean) {
+  return hasWord ? documentActionCopy.word.refresh : documentActionCopy.word.create;
+}
